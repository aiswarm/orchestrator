{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "lib": ["esnext"]
  },
  "include": ["*.js", "src/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "coverage", "dist"]
}
