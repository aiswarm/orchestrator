{
  "name": "@aiswarm/orchestrator",
  "version": "0.2.0",
  "description": "Organizes a swarm of AI agents to work together",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./agentDriver.js": "./src/agentDriver.js",
    "./agentSkill.js": "./src/agentSkill.js",
    "./contextProvider.js": "./src/contextProvider.js",
    "./message.js": "./src/message.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "author": "Ravi Gairola <mallox@pyxzl.net>",
  "license": "MIT",
  "dependencies": {
    "loglevel": "^1.8.1",
    "onall": "^3.0.0"
  },
  "optionalDependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.6.0",
    "vitest": "^4.1.5"
  }
}
